{
  "name": "n8n-integration",
  "version": "2.1.0",
  "description": "n8n workflow automation via Python CLI and MCP - workflows, executions, webhooks, and multi-account support",
  "author": {
    "name": "tchow",
    "url": "https://github.com/tchow-twistedxcom"
  },
  "homepage": "https://github.com/tchow-twistedxcom/claude-marketplace",
  "repository": "https://github.com/tchow-twistedxcom/claude-marketplace",
  "license": "MIT",
  "keywords": [
    "n8n",
    "workflow",
    "automation",
    "integration",
    "ai-agents",
    "mcp",
    "orchestration",
    "webhook"
  ],
  "mcpServers": {
    "n8n": {
      "command": "python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/n8n_mcp_wrapper.py"]
    },
    "celigo-tools": {
      "command": "python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/celigo_mcp_bridge.py"]
    },
    "edi-ops": {
      "command": "python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/edi_ops_mcp_bridge.py"]
    },
    "amazon-tools": {
      "command": "python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/amazon_mcp_bridge.py"]
    }
  },
  "commands": [
    "./commands/n8n-setup.md",
    "./commands/n8n-status.md",
    "./commands/n8n-list.md",
    "./commands/n8n-find.md",
    "./commands/n8n-run.md",
    "./commands/n8n-validate.md",
    "./commands/n8n-help.md"
  ],
  "skills": [
    "./skills/n8n-workflow-builder",
    "./skills/n8n-workflow-manager",
    "./skills/n8n-troubleshooter",
    "./skills/n8n-integration-patterns"
  ]
}
